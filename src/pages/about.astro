---
import Layout from '../components/Layout.astro';

// High-level career headline only - details live on LinkedIn.
const careerHighlights = [
  { label: 'Now', text: 'Senior SRE @ Microsoft - Data & Research Enablement' },
  { label: 'Before that', text: 'AT&T - DevOps Team Lead, Innovation Lead, DevOps / integration leadership' },
  { label: 'Startup', text: 'CTO & co-founder @ VADO Security - unidirectional networks / cross-domain data diode' },
  { label: 'Earlier', text: 'Head of Engineering at Oasis Communication Technologies · VoIP / backbone / hosting-sec at Internet Gold' },
  { label: 'Span', text: 'Across telco, enterprise, cybersecurity, and cloud - individual contributor through head-of-engineering' },
];

const credentials = [
  { label: 'Certified CISO', note: 'Chief Information Security Officer - See-Security College' },
  { label: 'DevSecOps Foundations', note: 'SSDLC, policy-as-code mindset' },
  { label: '4 issued / filed patents', note: 'unidirectional networking + software-defined sockets' },
  { label: 'Co-founder × 2', note: 'built engineering orgs from zero' },
];

const patents = [
  { title: 'Software-Defined Socket Activation', id: 'US 10,523,584' },
  { title: 'Directing data packets by a virtual switch over a unidirectional medium', id: 'WO2018104947A1' },
  { title: 'Position-based communication routing', id: 'US 2018/0063295' },
  { title: 'System and method for unidirectional communication management', id: 'US 2020/0304600 A1' },
];
---

<Layout title="Yossi Ben Hagai - Senior SRE · Platform · Security & Networking · Applied AI">
  <section class="about-hero">
    <div class="prompt mono">
      <span class="p-host">yossi@netrecon</span>:<span class="p-path">~/about</span>$ <span class="typed">whoami --summary</span>
    </div>

    <h1 class="about-h1">Yossi Ben Hagai</h1>
    <p class="about-lede">
      Senior SRE at Microsoft. Previously DevOps leadership at AT&amp;T, CTO of a cybersecurity
      startup, head of engineering at telco-scale networking shops. I work at the intersection of
      <strong>site reliability</strong>, <strong>software engineering</strong>,
      <strong>security &amp; networking</strong>, and <strong>applied AI</strong>.
    </p>
    <div class="about-pills mono">
      <span class="pill">senior sre</span>
      <span class="pill">platform eng</span>
      <span class="pill">zero trust</span>
      <span class="pill">k8s · iac</span>
      <span class="pill">llmops · rag · mcp</span>
      <span class="pill">4 patents</span>
      <span class="pill">ciso</span>
    </div>
  </section>

  <section class="about-section">
    <h2 class="about-h2">Where I work</h2>
    <p class="about-muted">
      Four disciplines, one operator. The most useful work lives on the edges between them -
      and increasingly, in the middle.
    </p>

    <div class="quadrant" role="img" aria-label="Quadrant showing the four disciplines and their intersections">
      <div class="q-card q-sre">
        <span class="q-tag mono">01 · sre / platform</span>
        <strong>Keep it up. Make it cheap. Tell the story.</strong>
        <span class="q-meta mono">SLOs · OpenTelemetry · K8s · ADO · FinOps · Azure</span>
      </div>
      <div class="q-card q-ai">
        <span class="q-tag mono">02 · applied AI</span>
        <strong>LLMs with guardrails, evals, and a job to do.</strong>
        <span class="q-meta mono">RAG · Agents · MCP · evals · AIOps</span>
      </div>
      <div class="q-card q-swe">
        <span class="q-tag mono">03 · software</span>
        <strong>Cloud-native, IaC-first, supply-chain-aware.</strong>
        <span class="q-meta mono">C# · Python · Go · Terraform · containers · SBOM/SLSA</span>
      </div>
      <div class="q-card q-sec">
        <span class="q-tag mono">04 · security &amp; networking</span>
        <strong>Zero trust. Real handshakes. Hard guarantees.</strong>
        <span class="q-meta mono">Zero Trust · Entra · PKI · PenTesting · cross-domain</span>
      </div>

      <span class="q-edge q-edge-top mono" aria-hidden="true">AIOps · LLMOps</span>
      <span class="q-edge q-edge-bottom mono" aria-hidden="true">DevSecOps · supply-chain security</span>
      <span class="q-edge q-edge-left mono" aria-hidden="true">Platform engineering</span>
      <span class="q-edge q-edge-right mono" aria-hidden="true">AI safety · secure agents</span>
      <span class="q-center mono" aria-hidden="true">sweet&nbsp;spot</span>
    </div>
  </section>

  <section class="about-section">
    <h2 class="about-h2">Track record</h2>
    <p class="about-muted">
      High-level only. Per-role detail lives on
      <a href="https://www.linkedin.com/in/yossibenhagai/" target="_blank" rel="noopener">LinkedIn</a>.
    </p>
    <ul class="career-list">
      {careerHighlights.map((c) => (
        <li>
          <span class="career-k mono">{c.label}</span>
          <span class="career-v">{c.text}</span>
        </li>
      ))}
    </ul>

    <div class="cred-grid">
      {credentials.map((c) => (
        <div class="cred">
          <span class="cred-label mono">{c.label}</span>
          <span class="cred-note">{c.note}</span>
        </div>
      ))}
    </div>
  </section>

  <section class="about-section">
    <h2 class="about-h2">Patents</h2>
    <p class="about-muted">
      Three on unidirectional / cross-domain networking - the kind of networking where
      <em>"just retry"</em> is not an option.
    </p>
    <ul class="patent-list">
      {patents.map((p) => (
        <li class="patent">
          <span class="patent-title">{p.title}</span>
          <span class="patent-meta mono">{p.id}</span>
        </li>
      ))}
    </ul>
  </section>

  <section class="about-section">
    <h2 class="about-h2">Now</h2>
    <p>
      Senior SRE at Microsoft, working on data &amp; research enablement. On the side,
      writing and building small things that keep me fluent in modern runtimes, LLM-tooled
      operations, and edge architectures - such as <a href="/">netrecon</a>, a
      correlated-diagnostics tool with an MCP interface.
    </p>
  </section>

  <section class="about-section">
    <h2 class="about-h2">Contact</h2>
    <ul class="contact-list mono">
      <li><span class="c-k">linkedin</span> <a href="https://www.linkedin.com/in/yossibenhagai/" target="_blank" rel="noopener">linkedin.com/in/yossibenhagai</a></li>
      <li><span class="c-k">github</span> <a href="https://github.com/Yossibh" target="_blank" rel="noopener">github.com/Yossibh</a></li>
      <li><span class="c-k">x / twitter</span> <a href="https://twitter.com/YossiBenHagai" target="_blank" rel="noopener">@YossiBenHagai</a></li>
      <li><span class="c-k">linktree</span> <a href="https://linktr.ee/yossibh" target="_blank" rel="noopener">linktr.ee/yossibh</a></li>
    </ul>
  </section>
</Layout>

<style>
  .about-hero { padding: 32px 0 8px; border-bottom: 1px solid var(--border); margin-bottom: 28px; }
  .about-hero .prompt { font-family: var(--mono); font-size: 13px; color: var(--fg-dim); margin: 0 0 18px; }
  .about-hero .prompt .p-host { color: var(--accent); }
  .about-hero .prompt .p-path { color: var(--low); }
  .about-hero .prompt .typed { color: var(--fg); }
  .about-h1 { font-size: 38px; line-height: 1.1; margin: 0 0 12px; letter-spacing: -0.015em; }
  .about-lede { font-size: 17px; color: var(--fg-dim); max-width: 760px; margin: 0 0 18px; }
  .about-lede strong { color: var(--fg); font-weight: 600; }
  .about-pills { display: flex; flex-wrap: wrap; gap: 6px; margin: 0; }
  .about-pills .pill {
    font-size: 11px; color: var(--fg-dim); border: 1px solid var(--border);
    border-radius: 999px; padding: 3px 10px; background: var(--bg-elev);
  }

  .about-section { padding: 28px 0; border-bottom: 1px dashed var(--border); }
  .about-section:last-of-type { border-bottom: 0; }
  .about-h2 {
    font-size: 12px; text-transform: uppercase; letter-spacing: 0.16em;
    color: var(--accent); font-family: var(--mono); margin: 0 0 14px; font-weight: 600;
  }
  .about-h2::before { content: "# "; color: var(--fg-dim); }
  .about-muted { color: var(--fg-dim); max-width: 760px; margin-top: 0; }
  .about-muted em { color: var(--fg); font-style: italic; }

  /* ── Quadrant visualization ──────────────────────────────────────────── */
  .quadrant {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    grid-template-rows: 1fr 1fr;
    gap: 14px;
    margin-top: 20px;
    padding: 36px 34px;
    border: 1px solid var(--border);
    border-radius: 8px;
    background:
      radial-gradient(ellipse at center, rgba(92,210,163,0.08), transparent 60%),
      var(--bg-elev);
  }
  .q-card {
    display: flex; flex-direction: column; gap: 8px;
    padding: 16px 18px;
    background: var(--bg);
    border: 1px solid var(--border);
    border-radius: 6px;
    min-height: 130px;
    transition: border-color .12s ease, transform .12s ease;
  }
  .q-card:hover { border-color: var(--accent-dim); transform: translateY(-1px); }
  .q-tag { font-size: 10px; letter-spacing: 0.14em; text-transform: uppercase; color: var(--accent); }
  .q-card strong { font-size: 15px; color: var(--fg); font-weight: 600; line-height: 1.35; }
  .q-meta { font-size: 11px; color: var(--fg-dim); margin-top: auto; }

  .q-edge {
    position: absolute;
    font-size: 10px; text-transform: uppercase; letter-spacing: 0.18em;
    color: var(--accent); opacity: 0.78;
    background: var(--bg-elev);
    padding: 3px 8px;
    border: 1px solid var(--border);
    border-radius: 3px;
    white-space: nowrap;
    pointer-events: none;
  }
  .q-edge-top    { top: 18px; left: 50%; transform: translateX(-50%); }
  .q-edge-bottom { bottom: 18px; left: 50%; transform: translateX(-50%); }
  .q-edge-left   { top: 50%; left: 6px;  writing-mode: vertical-rl; transform: translateY(-50%) rotate(180deg); }
  .q-edge-right  { top: 50%; right: 6px; writing-mode: vertical-rl; transform: translateY(-50%); }

  .q-center {
    position: absolute;
    top: 50%; left: 50%; transform: translate(-50%, -50%);
    font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase;
    color: var(--bg);
    background: var(--accent);
    padding: 6px 14px;
    border-radius: 999px;
    font-weight: 700;
    box-shadow: 0 0 0 4px var(--bg-elev), 0 0 0 5px var(--accent-dim);
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .quadrant { grid-template-columns: 1fr; grid-template-rows: auto; padding: 20px 14px; }
    .q-edge-left, .q-edge-right { display: none; }
    .q-edge-top, .q-edge-bottom { position: static; transform: none; display: inline-block; margin: 6px 4px; }
    .q-center { position: static; transform: none; display: inline-block; margin: 10px 0; }
  }

  /* ── Track record ─────────────────────────────────────────────────────── */
  .career-list { list-style: none; padding: 0; margin: 10px 0 20px; display: flex; flex-direction: column; gap: 6px; }
  .career-list li { display: grid; grid-template-columns: 110px 1fr; gap: 14px; align-items: baseline; padding: 4px 0; }
  .career-k { color: var(--accent); font-size: 11px; text-transform: uppercase; letter-spacing: 0.12em; }
  .career-v { color: var(--fg); }

  .cred-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 10px; margin-top: 14px; }
  .cred { display: flex; flex-direction: column; gap: 2px; border-left: 2px solid var(--accent-dim); padding: 4px 0 4px 12px; }
  .cred-label { font-size: 13px; color: var(--fg); font-weight: 600; }
  .cred-note { font-size: 12px; color: var(--fg-dim); }

  /* ── Patents ──────────────────────────────────────────────────────────── */
  .patent-list { list-style: none; padding: 0; margin: 10px 0 0; display: flex; flex-direction: column; gap: 8px; }
  .patent { display: flex; flex-wrap: wrap; gap: 10px; align-items: baseline; border-left: 2px solid var(--accent-dim); padding: 4px 0 4px 12px; }
  .patent-title { font-weight: 500; color: var(--fg); }
  .patent-meta { font-size: 12px; color: var(--fg-dim); }

  /* ── Contact ──────────────────────────────────────────────────────────── */
  .contact-list { list-style: none; padding: 0; margin: 0; font-size: 14px; }
  .contact-list li { padding: 4px 0; }
  .contact-list .c-k { display: inline-block; min-width: 100px; color: var(--fg-dim); }
  .contact-list .c-k::after { content: ":"; }

  @media (max-width: 640px) {
    .about-h1 { font-size: 28px; }
    .about-lede { font-size: 15px; }
    .career-list li { grid-template-columns: 1fr; gap: 2px; }
  }
</style>
