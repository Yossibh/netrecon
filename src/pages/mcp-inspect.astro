---
import Layout from '../components/Layout.astro';
---
<Layout title="netrecon - MCP inspector" description="Browser-native MCP client. Paste an MCP server URL, enumerate its tools / prompts / resources, and invoke them. Supports Streamable HTTP and legacy SSE.">
  <section class="decode-hero">
    <div class="prompt mono">$ netrecon mcp-inspect</div>
    <h1>MCP inspector.</h1>
    <p class="tagline">Connect to any remote MCP server from your browser. List tools, prompts, resources. Invoke and inspect raw JSON-RPC.</p>
    <p class="privacy-note">
      <span class="lock">&#128274;</span>
      Connects directly from your browser to the server you enter. Tokens are held in memory only (no localStorage, no logging).
    </p>
  </section>

  <section class="mcp-inspect-form">
    <div class="row">
      <label class="field grow">
        <span>Server URL</span>
        <input id="mcp-url" type="url" placeholder="https://your-mcp-server.example/mcp" autocomplete="off" spellcheck="false" />
      </label>
      <label class="field">
        <span>Bearer token (optional)</span>
        <input id="mcp-token" type="password" placeholder="optional" autocomplete="off" />
      </label>
      <button id="mcp-connect" type="button" class="primary">Connect</button>
    </div>
    <div class="hint mono">
      Examples:
      <button type="button" data-sample="https://mcp.deepwiki.com/mcp">deepwiki</button>
      <button type="button" data-sample="https://api.githubcopilot.com/mcp/readonly">github readonly</button>
    </div>
  </section>

  <section id="mcp-status" class="decode-output"></section>
  <section id="mcp-report" class="decode-output"></section>

  <script>
    const urlEl = document.getElementById('mcp-url') as HTMLInputElement;
    const tokenEl = document.getElementById('mcp-token') as HTMLInputElement;
    const connectBtn = document.getElementById('mcp-connect') as HTMLButtonElement;
    const statusEl = document.getElementById('mcp-status') as HTMLElement;
    const reportEl = document.getElementById('mcp-report') as HTMLElement;

    function h(tag: string, attrs: Record<string, string> = {}, ...kids: (Node | string | null)[]): HTMLElement {
      const el = document.createElement(tag);
      for (const [k, v] of Object.entries(attrs)) {
        if (k === 'class') el.className = v; else el.setAttribute(k, v);
      }
      for (const k of kids) {
        if (k == null) continue;
        el.appendChild(typeof k === 'string' ? document.createTextNode(k) : k);
      }
      return el;
    }
    function kv(rows: Array<[string, string]>): HTMLElement {
      const tbl = h('table', { class: 'kv-table' });
      for (const [k, v] of rows) tbl.appendChild(h('tr', {}, h('th', {}, k), h('td', { class: 'mono' }, v)));
      return tbl;
    }
    function badge(sev: string) { return h('span', { class: `badge ${sev}` }, sev); }

    // ---- JSON-RPC client (Streamable HTTP, single endpoint) ------------------
    class McpClient {
      url: string;
      token: string;
      sessionId: string | null = null;
      nextId = 1;
      protocolVersion = '2025-06-18';
      log: Array<{ ts: string; dir: 'send' | 'recv'; payload: unknown }> = [];

      constructor(url: string, token: string) { this.url = url; this.token = token; }

      private async rpc(method: string, params?: unknown, isNotification = false): Promise<any> {
        const id = isNotification ? undefined : this.nextId++;
        const body: any = { jsonrpc: '2.0', method };
        if (!isNotification) body.id = id;
        if (params !== undefined) body.params = params;
        this.log.push({ ts: new Date().toISOString(), dir: 'send', payload: body });

        const headers: Record<string, string> = {
          'content-type': 'application/json',
          accept: 'application/json, text/event-stream',
        };
        if (this.token) headers.authorization = `Bearer ${this.token}`;
        if (this.sessionId) headers['mcp-session-id'] = this.sessionId;

        const res = await fetch(this.url, { method: 'POST', headers, body: JSON.stringify(body) });
        const sid = res.headers.get('mcp-session-id');
        if (sid) this.sessionId = sid;

        if (isNotification) {
          if (!res.ok && res.status !== 202) throw new Error(`notification ${method} failed: HTTP ${res.status}`);
          return null;
        }
        if (!res.ok) {
          let msg = `HTTP ${res.status}`;
          try { const t = await res.text(); if (t) msg += ` - ${t.slice(0, 200)}`; } catch {}
          throw new Error(msg);
        }

        const ct = res.headers.get('content-type') || '';
        if (ct.includes('text/event-stream')) {
          const obj = await readSseMessage(res.body!, id!);
          this.log.push({ ts: new Date().toISOString(), dir: 'recv', payload: obj });
          if (obj.error) throw new Error(`${obj.error.code}: ${obj.error.message}`);
          return obj.result;
        } else {
          const obj = await res.json();
          this.log.push({ ts: new Date().toISOString(), dir: 'recv', payload: obj });
          if (obj.error) throw new Error(`${obj.error.code}: ${obj.error.message}`);
          return obj.result;
        }
      }

      async initialize() {
        const r = await this.rpc('initialize', {
          protocolVersion: this.protocolVersion,
          capabilities: {},
          clientInfo: { name: 'netrecon-inspector', version: '1.0.0' },
        });
        await this.rpc('notifications/initialized', undefined, true).catch(() => {});
        return r;
      }
      listTools() { return this.rpc('tools/list'); }
      listPrompts() { return this.rpc('prompts/list').catch(() => null); }
      listResources() { return this.rpc('resources/list').catch(() => null); }
      callTool(name: string, args: unknown) { return this.rpc('tools/call', { name, arguments: args }); }
    }

    async function readSseMessage(stream: ReadableStream<Uint8Array>, wantId: number): Promise<any> {
      const reader = stream.getReader();
      const dec = new TextDecoder();
      let buf = '';
      while (true) {
        const { value, done } = await reader.read();
        if (done) break;
        buf += dec.decode(value, { stream: true });
        let idx;
        while ((idx = buf.indexOf('\n\n')) !== -1) {
          const evt = buf.slice(0, idx);
          buf = buf.slice(idx + 2);
          const dataLines = evt.split('\n').filter((l) => l.startsWith('data:')).map((l) => l.slice(5).trimStart());
          if (!dataLines.length) continue;
          try {
            const obj = JSON.parse(dataLines.join('\n'));
            if (obj.id === wantId || (!('id' in obj) && obj.error)) {
              try { await reader.cancel(); } catch {}
              return obj;
            }
          } catch { /* ignore non-JSON event */ }
        }
      }
      throw new Error('SSE stream ended before matching response arrived');
    }

    // ---- Schema-to-form ------------------------------------------------------
    function renderSchemaField(key: string, schema: any, required: boolean, path: string[]): { el: HTMLElement; read: () => unknown } {
      const full = [...path, key].join('.');
      const wrap = h('label', { class: 'field' });
      const labelTxt = `${key}${required ? ' *' : ''}${schema.description ? ` - ${schema.description}` : ''}`;
      wrap.appendChild(h('span', {}, labelTxt));

      const type = schema.type || (schema.enum ? 'string' : 'string');
      let input: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;

      if (schema.enum && Array.isArray(schema.enum)) {
        const sel = document.createElement('select');
        if (!required) sel.appendChild(new Option('(unset)', ''));
        for (const v of schema.enum) sel.appendChild(new Option(String(v), String(v)));
        input = sel;
      } else if (type === 'boolean') {
        const i = document.createElement('input'); i.type = 'checkbox'; input = i;
      } else if (type === 'number' || type === 'integer') {
        const i = document.createElement('input'); i.type = 'number';
        if (type === 'integer') i.step = '1';
        input = i;
      } else if (type === 'object' || type === 'array') {
        const ta = document.createElement('textarea'); ta.placeholder = `${type} - paste JSON`; ta.rows = 3;
        input = ta;
      } else {
        const i = document.createElement('input'); i.type = 'text';
        if (schema.default != null) i.value = String(schema.default);
        input = i;
      }
      input.setAttribute('data-path', full);
      wrap.appendChild(input);

      const read = (): unknown => {
        if (input instanceof HTMLSelectElement) return input.value === '' ? undefined : input.value;
        if (input instanceof HTMLInputElement && input.type === 'checkbox') return input.checked;
        const raw = input.value;
        if (!raw.length) return undefined;
        if (type === 'number' || type === 'integer') return Number(raw);
        if (type === 'object' || type === 'array') { try { return JSON.parse(raw); } catch { throw new Error(`${full}: invalid JSON`); } }
        return raw;
      };
      return { el: wrap, read };
    }

    function renderToolForm(tool: any, onInvoke: (args: Record<string, unknown>) => Promise<void>): HTMLElement {
      const schema = tool.inputSchema || { type: 'object', properties: {} };
      const props = schema.properties || {};
      const required: string[] = schema.required || [];
      const form = h('div', { class: 'mcp-form' });
      const readers: Array<[string, () => unknown]> = [];
      for (const [k, s] of Object.entries(props)) {
        const { el, read } = renderSchemaField(k, s, required.includes(k), []);
        form.appendChild(el);
        readers.push([k, read]);
      }
      const btn = h('button', { class: 'primary' }, 'Invoke');
      const resultEl = h('pre', { class: 'mono mcp-result hidden' });
      btn.addEventListener('click', async () => {
        try {
          const args: Record<string, unknown> = {};
          for (const [k, r] of readers) {
            const v = r();
            if (v !== undefined) args[k] = v;
          }
          resultEl.classList.remove('hidden');
          resultEl.textContent = 'Invoking...';
          await onInvoke(args).then(() => {}).catch((err) => { resultEl.textContent = `Error: ${err.message || err}`; });
        } catch (err: any) {
          resultEl.textContent = `Error: ${err.message || err}`;
          resultEl.classList.remove('hidden');
        }
      });
      form.appendChild(btn);
      form.appendChild(resultEl);
      (form as any).__setResult = (text: string) => { resultEl.classList.remove('hidden'); resultEl.textContent = text; };
      return form;
    }

    // ---- Connect + enumerate -------------------------------------------------
    async function connect() {
      const url = urlEl.value.trim();
      const token = tokenEl.value.trim();
      if (!url) { statusEl.textContent = 'Enter a URL.'; return; }

      statusEl.innerHTML = '';
      reportEl.innerHTML = '';
      statusEl.appendChild(h('div', { class: 'loading' }, 'Connecting...'));

      const client = new McpClient(url, token);
      let initResult: any;
      try {
        initResult = await client.initialize();
      } catch (err: any) {
        statusEl.innerHTML = '';
        const msg = err.message || String(err);
        statusEl.appendChild(h('div', { class: 'finding severity-high' },
          h('strong', {}, 'Connection failed'),
          h('p', {}, msg),
          h('p', { class: 'mono', style: 'margin-top:8px;opacity:.75' },
            /CORS|Failed to fetch|NetworkError/i.test(msg)
              ? 'Likely CORS: the server does not allow browser-origin requests. Try from a CLI:'
              : 'Try from a CLI to cross-check:'),
          h('pre', { class: 'cmd' }, `curl -X POST '${url}' \\\n  -H 'content-type: application/json' \\\n  -H 'accept: application/json, text/event-stream' \\${token ? `\n  -H 'authorization: Bearer <token>' \\` : ''}\n  -d '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2025-06-18","capabilities":{},"clientInfo":{"name":"curl","version":"1"}}}'`),
        ));
        return;
      }

      statusEl.innerHTML = '';
      const [tools, prompts, resources] = await Promise.all([
        client.listTools().catch((e) => ({ error: e.message })),
        client.listPrompts().catch(() => null),
        client.listResources().catch(() => null),
      ]);

      // Server summary
      const si = initResult.serverInfo || {};
      const caps = initResult.capabilities || {};
      reportEl.appendChild(h('div', { class: 'panel' },
        h('h2', {}, `${si.name || 'MCP Server'}${si.version ? ' v' + si.version : ''}`),
        kv([
          ['Protocol', initResult.protocolVersion || '-'],
          ['Session ID', client.sessionId || '-'],
          ['Capabilities', Object.keys(caps).join(', ') || 'none'],
          ['Instructions', initResult.instructions ? initResult.instructions.slice(0, 180) + (initResult.instructions.length > 180 ? '...' : '') : '-'],
        ])
      ));

      // Tabs
      const tabNames = ['Tools', ...(prompts?.prompts?.length ? ['Prompts'] : []), ...(resources?.resources?.length ? ['Resources'] : []), 'Log'];
      const tabBar = h('div', { class: 'tabs' });
      const panels: Record<string, HTMLElement> = {};
      tabNames.forEach((t, i) => {
        const btn = h('button', { class: i === 0 ? 'active' : '' }, t);
        btn.addEventListener('click', () => {
          tabBar.querySelectorAll('button').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          Object.values(panels).forEach((p) => p.classList.add('hidden'));
          panels[t].classList.remove('hidden');
        });
        tabBar.appendChild(btn);
      });
      reportEl.appendChild(tabBar);

      // Tools
      const toolsPanel = h('div', { class: 'panel' });
      if ((tools as any).error) {
        toolsPanel.appendChild(h('div', { class: 'finding severity-medium' }, `tools/list failed: ${(tools as any).error}`));
      } else {
        const toolList = ((tools as any).tools || []) as any[];
        if (!toolList.length) toolsPanel.appendChild(h('div', { class: 'loading' }, 'No tools exposed.'));
        for (const t of toolList) {
          const det = h('details', { class: 'mcp-tool' });
          det.appendChild(h('summary', {}, h('code', {}, t.name), ' ', h('span', { class: 'mono', style: 'opacity:.7' }, t.description?.slice(0, 140) || '')));
          const form = renderToolForm(t, async (args) => {
            const res = await client.callTool(t.name, args);
            (form as any).__setResult(JSON.stringify(res, null, 2));
          });
          det.appendChild(form);
          toolsPanel.appendChild(det);
        }
      }
      panels['Tools'] = toolsPanel;
      reportEl.appendChild(toolsPanel);

      // Prompts
      if (tabNames.includes('Prompts')) {
        const p = h('div', { class: 'panel hidden' });
        for (const pr of (prompts as any).prompts || []) {
          p.appendChild(h('div', { class: 'mcp-tool' }, h('code', {}, pr.name), ' ', h('span', { class: 'mono', style: 'opacity:.7' }, pr.description || '')));
        }
        panels['Prompts'] = p;
        reportEl.appendChild(p);
      }
      // Resources
      if (tabNames.includes('Resources')) {
        const p = h('div', { class: 'panel hidden' });
        for (const r of (resources as any).resources || []) {
          p.appendChild(h('div', { class: 'mcp-tool' }, h('code', {}, r.uri), ' ', h('span', { class: 'mono', style: 'opacity:.7' }, (r.name || r.description || ''))));
        }
        panels['Resources'] = p;
        reportEl.appendChild(p);
      }

      // Log
      const logPanel = h('div', { class: 'panel hidden' });
      const refreshLog = () => {
        logPanel.innerHTML = '';
        const btn = h('button', {}, 'Refresh');
        btn.addEventListener('click', refreshLog);
        logPanel.appendChild(btn);
        for (const entry of client.log.slice().reverse()) {
          logPanel.appendChild(h('pre', { class: 'cmd', style: entry.dir === 'send' ? 'border-left:3px solid #4af' : 'border-left:3px solid #4f4' },
            `${entry.ts} ${entry.dir.toUpperCase()}\n${JSON.stringify(entry.payload, null, 2)}`));
        }
      };
      refreshLog();
      panels['Log'] = logPanel;
      reportEl.appendChild(logPanel);

      reportEl.appendChild(h('div', { class: 'mono', style: 'margin-top:16px;opacity:.7;font-size:.9em' },
        'Want to audit this server for security issues? ',
        h('a', { href: `/mcp-scan?url=${encodeURIComponent(url)}` }, 'Run the security scanner →')
      ));
    }

    connectBtn.addEventListener('click', connect);
    urlEl.addEventListener('keydown', (e) => { if (e.key === 'Enter') connect(); });
    document.querySelectorAll<HTMLButtonElement>('.hint button[data-sample]').forEach((b) => {
      b.addEventListener('click', () => { urlEl.value = b.getAttribute('data-sample') || ''; });
    });

    // deep-link: ?url=...
    const q = new URL(window.location.href).searchParams.get('url');
    if (q) { urlEl.value = q; connect(); }
  </script>
</Layout>

<style>
  .mcp-inspect-form .row { display: flex; gap: 12px; align-items: flex-end; flex-wrap: wrap; }
  .mcp-inspect-form .field { display: flex; flex-direction: column; gap: 4px; }
  .mcp-inspect-form .field.grow { flex: 1 1 300px; }
  .mcp-inspect-form input[type=text], .mcp-inspect-form input[type=url], .mcp-inspect-form input[type=password] {
    padding: 8px 10px; border: 1px solid var(--border, #333); background: var(--bg-input, #111); color: inherit; border-radius: 4px;
  }
  .mcp-inspect-form .hint { margin-top: 8px; font-size: .85em; opacity: .7; }
  .mcp-inspect-form .hint button { margin-left: 8px; }
  .mcp-tool { margin: 8px 0; padding: 8px; border: 1px solid var(--border, #333); border-radius: 4px; }
  .mcp-form { display: flex; flex-direction: column; gap: 8px; margin-top: 8px; }
  .mcp-form .field { display: flex; flex-direction: column; gap: 4px; }
  .mcp-form input, .mcp-form textarea, .mcp-form select {
    padding: 6px 8px; border: 1px solid var(--border, #333); background: var(--bg-input, #111); color: inherit; border-radius: 3px;
  }
  .mcp-result { max-height: 400px; overflow: auto; }
</style>
