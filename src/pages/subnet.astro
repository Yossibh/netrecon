---
import Layout from '../components/Layout.astro';
---
<Layout title="netrecon - subnet calculator" description="Client-side IPv4 / IPv6 subnet calculator. Network, broadcast, host range, wildcard, and split. Nothing leaves your browser.">
  <section class="decode-hero">
    <div class="prompt mono">$ netrecon subnet</div>
    <h1>Subnet calculator.</h1>
    <p class="tagline">IPv4 · IPv6 · CIDR math · wildcard mask · split into smaller prefixes</p>
    <p class="privacy-note">
      <span class="lock">&#128274;</span>
      Runs entirely in your browser. No network request, no logs.
    </p>
  </section>

  <section class="decode-input">
    <input id="subnet-in" type="text" spellcheck="false" autocomplete="off"
           placeholder="10.0.0.0/24  ·  192.168.1.42/22  ·  2001:db8::/48" />
    <div class="decode-examples">
      try:
      <button type="button" data-sample="10.0.0.0/24">/24</button>
      <button type="button" data-sample="192.168.1.42/22">/22</button>
      <button type="button" data-sample="172.16.5.9/30">/30 p2p</button>
      <button type="button" data-sample="203.0.113.0/26">/26</button>
      <button type="button" data-sample="2001:db8::/48">IPv6 /48</button>
    </div>
  </section>

  <section id="subnet-out" class="decode-output"></section>

  <script>
    const input = document.getElementById('subnet-in') as HTMLInputElement;
    const output = document.getElementById('subnet-out') as HTMLElement;

    function h(tag: string, attrs: Record<string, string> = {}, ...kids: (Node | string | null)[]): HTMLElement {
      const el = document.createElement(tag);
      for (const [k, v] of Object.entries(attrs)) {
        if (k === 'class') el.className = v;
        else el.setAttribute(k, v);
      }
      for (const k of kids) {
        if (k == null) continue;
        el.appendChild(typeof k === 'string' ? document.createTextNode(k) : k);
      }
      return el;
    }

    function kv(rows: Array<[string, string]>): HTMLElement {
      const tbl = h('table', { class: 'kv-table' });
      for (const [k, v] of rows) {
        tbl.appendChild(h('tr', {}, h('th', {}, k), h('td', { class: 'mono' }, v)));
      }
      return tbl;
    }

    // ---- IPv4 ------------------------------------------------------------
    function parseIpv4(s: string): number | null {
      const m = s.split('.');
      if (m.length !== 4) return null;
      let n = 0;
      for (const p of m) {
        if (!/^\d+$/.test(p)) return null;
        const v = Number(p);
        if (v < 0 || v > 255) return null;
        n = (n * 256) + v;
      }
      return n >>> 0;
    }
    function formatIpv4(n: number): string {
      return [(n >>> 24) & 255, (n >>> 16) & 255, (n >>> 8) & 255, n & 255].join('.');
    }
    function v4Report(ip: number, prefix: number) {
      const hostBits = 32 - prefix;
      const mask = prefix === 0 ? 0 : ((0xffffffff << hostBits) >>> 0);
      const network = (ip & mask) >>> 0;
      const broadcast = (network | ((1 << hostBits) - 1 >>> 0)) >>> 0;
      const total = Math.pow(2, hostBits);
      const usable = prefix >= 31 ? total : Math.max(0, total - 2);
      const first = prefix >= 31 ? network : (network + 1) >>> 0;
      const last = prefix >= 31 ? broadcast : (broadcast - 1) >>> 0;
      const wildcard = (~mask) >>> 0;
      const isPrivate =
        (network & 0xff000000) >>> 24 === 10 ||
        ((network & 0xfff00000) >>> 20) === 0xac1 ||
        ((network & 0xffff0000) >>> 16) === 0xc0a8;
      const isLoopback = ((network & 0xff000000) >>> 24) === 127;
      const isLinkLocal = ((network & 0xffff0000) >>> 16) === 0xa9fe;
      const isMulticast = ((network & 0xf0000000) >>> 28) === 0xe;
      const scope = isLoopback ? 'loopback' :
        isLinkLocal ? 'link-local' :
        isMulticast ? 'multicast' :
        isPrivate ? 'private (RFC1918)' : 'public';

      return kv([
        ['Family', 'IPv4'],
        ['CIDR', formatIpv4(network) + '/' + prefix],
        ['Netmask', formatIpv4(mask)],
        ['Wildcard', formatIpv4(wildcard)],
        ['Network', formatIpv4(network)],
        ['Broadcast', formatIpv4(broadcast)],
        ['First host', formatIpv4(first)],
        ['Last host', formatIpv4(last)],
        ['Total addresses', total.toLocaleString()],
        ['Usable hosts', usable.toLocaleString()],
        ['Scope', scope],
      ]);
    }

    // ---- IPv6 (BigInt) ---------------------------------------------------
    function parseIpv6(s: string): bigint | null {
      let str = s.trim();
      if (str.startsWith('[') && str.endsWith(']')) str = str.slice(1, -1);
      if (!str.includes(':')) return null;
      const [head, tail] = str.split('::');
      const hParts = head ? head.split(':') : [];
      const tParts = tail != null && tail !== '' ? tail.split(':') : [];
      const total = hParts.length + tParts.length;
      if (total > 8) return null;
      if (tail == null && total !== 8) return null;
      const gapLen = 8 - total;
      const all = [...hParts, ...Array(gapLen).fill('0'), ...tParts];
      let n = 0n;
      for (const p of all) {
        if (!/^[0-9a-fA-F]{1,4}$/.test(p)) return null;
        n = (n << 16n) | BigInt(parseInt(p, 16));
      }
      return n;
    }
    function formatIpv6(n: bigint): string {
      const parts: string[] = [];
      for (let i = 7; i >= 0; i--) {
        parts.push(((n >> BigInt(i * 16)) & 0xffffn).toString(16));
      }
      // RFC 5952 compression of the longest run of zero groups
      let bestStart = -1, bestLen = 0, curStart = -1, curLen = 0;
      for (let i = 0; i < 8; i++) {
        if (parts[i] === '0') {
          if (curStart === -1) curStart = i;
          curLen++;
          if (curLen > bestLen) { bestStart = curStart; bestLen = curLen; }
        } else {
          curStart = -1; curLen = 0;
        }
      }
      if (bestLen < 2) return parts.join(':');
      const left = parts.slice(0, bestStart).join(':');
      const right = parts.slice(bestStart + bestLen).join(':');
      return `${left}::${right}`;
    }
    function v6Report(ip: bigint, prefix: number) {
      const hostBits = 128 - prefix;
      const mask = prefix === 0 ? 0n : ((1n << BigInt(prefix)) - 1n) << BigInt(hostBits);
      const network = ip & mask;
      const last = network | ((1n << BigInt(hostBits)) - 1n);
      const total = 1n << BigInt(hostBits);
      const scope =
        (network >> 121n) === 0n && network === 1n ? 'loopback (::1)' :
        (network >> 112n) === 0xfe80n / 16n ? 'link-local (fe80::/10)' :
        ((network >> 121n) & 0xfen) === 0xfcn ? 'unique local (fc00::/7)' :
        ((network >> 120n) & 0xffn) === 0xffn ? 'multicast' :
        'global unicast';
      return kv([
        ['Family', 'IPv6'],
        ['CIDR', formatIpv6(network) + '/' + prefix],
        ['Network', formatIpv6(network)],
        ['Last address', formatIpv6(last)],
        ['Total addresses', total.toString()],
        ['Scope', scope],
      ]);
    }

    // ---- Entry ----------------------------------------------------------
    function render() {
      output.innerHTML = '';
      const raw = input.value.trim();
      if (!raw) return;
      const [addr, prefStr] = raw.split('/');
      let prefix: number | undefined = prefStr == null ? undefined : Number(prefStr);

      if (addr.includes(':')) {
        const n = parseIpv6(addr);
        if (n == null) {
          output.appendChild(h('div', { class: 'loading' }, 'Not a valid IPv6 address.'));
          return;
        }
        if (prefix == null) prefix = 128;
        if (!Number.isInteger(prefix) || prefix < 0 || prefix > 128) {
          output.appendChild(h('div', { class: 'loading' }, 'IPv6 prefix must be 0-128.'));
          return;
        }
        output.appendChild(v6Report(n, prefix));
        return;
      }

      const n = parseIpv4(addr);
      if (n == null) {
        output.appendChild(h('div', { class: 'loading' }, 'Not a valid IPv4 address or CIDR.'));
        return;
      }
      if (prefix == null) prefix = 32;
      if (!Number.isInteger(prefix) || prefix < 0 || prefix > 32) {
        output.appendChild(h('div', { class: 'loading' }, 'IPv4 prefix must be 0-32.'));
        return;
      }
      output.appendChild(v4Report(n, prefix));
    }

    input.addEventListener('input', render);
    document.querySelectorAll<HTMLButtonElement>('.decode-examples button[data-sample]').forEach((btn) => {
      btn.addEventListener('click', () => {
        input.value = btn.getAttribute('data-sample') || '';
        render();
      });
    });

    // deep-link: /subnet?q=10.0.0.0/24
    const q = new URL(window.location.href).searchParams.get('q');
    if (q) { input.value = q; render(); }
  </script>
</Layout>
