---
import Layout from '../components/Layout.astro';

const homeSchema = [
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'netrecon',
    applicationCategory: 'DeveloperApplication',
    operatingSystem: 'Web',
    url: 'https://netrecon.pages.dev',
    description: 'Correlated network diagnostics for engineers. DNS, HTTP, TLS, email posture, and CDN inference - with findings, not just data.',
    author: {
      '@type': 'Person',
      name: 'Yossi Ben Hagai',
      url: 'https://yossibh.github.io/',
      sameAs: [
        'https://yossibh.github.io/',
        'https://github.com/Yossibh',
        'https://www.linkedin.com/in/yossibenhagai/',
      ],
    },
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'USD' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'netrecon',
    url: 'https://netrecon.pages.dev',
    potentialAction: {
      '@type': 'SearchAction',
      target: 'https://netrecon.pages.dev/?input={input}',
      'query-input': 'required name=input',
    },
  },
];
---
<Layout schema={homeSchema}>
  <section class="hero">
    <div class="prompt mono" id="prompt-line"><span class="p-host">yossi@netrecon</span>:<span class="p-path">~</span>$ <span id="typed-cmd"></span><span class="cursor" id="cursor">&#9608;</span></div>

    <h1 class="headline" id="headline"><span class="h-reveal">See through the network.</span></h1>

    <div class="taglines">
      <p class="tagline">DNS. HTTP. TLS. Email posture. CDN and origin inference.</p>
      <p class="tagline">Correlated into findings, not just dumps of raw records.</p>
      <p class="tagline">Every check ships with the exact command to reproduce it.</p>
    </div>

    <div class="module-pills mono" aria-hidden="true">
      <span class="pill">dns</span><span class="pill">http</span><span class="pill">tls</span><span class="pill">email</span><span class="pill">inference</span><span class="pill">findings</span>
    </div>

    <form id="analyze-form" class="input-row" autocomplete="off">
      <input id="input" type="text" placeholder="example.com  ·  https://example.com/path  ·  1.1.1.1" required />
      <button class="primary" type="submit" id="go">Analyze</button>
    </form>
    <label class="live-toggle mono" title="Enables Cloudflare Browser Rendering fallback for CF-fronted / TLS 1.3-only targets. Adds ~3-5s when it fires.">
      <input type="checkbox" id="live-full" />
      <span>live TLS: full (browser fallback for CF-fronted hosts; slower)</span>
    </label>
    <div class="examples">
      try:
      <button type="button" data-ex="cloudflare.com">cloudflare.com</button>
      <button type="button" data-ex="github.com">github.com</button>
      <button type="button" data-ex="https://www.google.com/search">https://www.google.com/search</button>
      <button type="button" data-ex="1.1.1.1">1.1.1.1</button>
    </div>

    <aside class="fingerprint" id="fingerprint" aria-label="Your network fingerprint">
      <div class="fp-head">
        <span class="fp-title mono">$ whoami</span>
        <span class="fp-sub">What the internet sees about your session</span>
      </div>
      <div class="fp-grid" id="fp-grid">
        <div class="fp-cell"><span class="fp-k">IP</span><span class="fp-v mono" id="fp-ip">-</span></div>
        <div class="fp-cell"><span class="fp-k">ASN</span><span class="fp-v mono" id="fp-asn">-</span></div>
        <div class="fp-cell"><span class="fp-k">Network</span><span class="fp-v" id="fp-org">-</span></div>
        <div class="fp-cell"><span class="fp-k">Location</span><span class="fp-v" id="fp-loc">-</span></div>
        <div class="fp-cell"><span class="fp-k">Timezone</span><span class="fp-v mono" id="fp-tz">-</span></div>
        <div class="fp-cell"><span class="fp-k">CF edge</span><span class="fp-v mono" id="fp-colo">-</span></div>
        <div class="fp-cell"><span class="fp-k">Protocol</span><span class="fp-v mono" id="fp-proto">-</span></div>
        <div class="fp-cell"><span class="fp-k">TLS</span><span class="fp-v mono" id="fp-tls">-</span></div>
        <div class="fp-cell"><span class="fp-k">Client</span><span class="fp-v" id="fp-client">-</span></div>
      </div>
      <div class="fp-actions">
        <button type="button" class="fp-btn" id="fp-analyze" disabled>Analyze my IP</button>
        <button type="button" class="fp-btn ghost" id="fp-copy">Copy as JSON</button>
      </div>
    </aside>
  </section>

  <script is:inline>
    (function () {
      var set = function (id, v) { var el = document.getElementById(id); if (el) el.textContent = v || '-'; };
      var data = null;
      fetch('/api/whoami', { headers: { accept: 'application/json' } })
        .then(function (r) { return r.json(); })
        .then(function (j) {
          data = j;
          set('fp-ip', j.ip || 'unknown');
          set('fp-asn', j.network && j.network.asn ? j.network.asn : '-');
          set('fp-org', j.network && j.network.asOrganization ? j.network.asOrganization : '-');
          var loc = [j.geo && j.geo.city, j.geo && j.geo.regionCode, j.geo && j.geo.country].filter(Boolean).join(', ');
          set('fp-loc', loc || '-');
          set('fp-tz', j.geo && j.geo.timezone ? j.geo.timezone : '-');
          set('fp-colo', j.network && j.network.colo ? j.network.colo : '-');
          set('fp-proto', j.connection && j.connection.httpProtocol ? j.connection.httpProtocol : '-');
          var tls = (j.connection && j.connection.tlsVersion) ? j.connection.tlsVersion + (j.connection.tlsCipher ? ' / ' + j.connection.tlsCipher : '') : '-';
          set('fp-tls', tls);
          set('fp-client', j.client ? ((j.client.browser || 'unknown') + ' on ' + (j.client.os || 'unknown')) : '-');
          var btn = document.getElementById('fp-analyze');
          if (btn && j.ip) {
            btn.disabled = false;
            btn.textContent = 'Analyze ' + j.ip;
          }
        })
        .catch(function () {
          set('fp-ip', 'lookup failed');
        });
      var ana = document.getElementById('fp-analyze');
      if (ana) ana.addEventListener('click', function () {
        if (!data || !data.ip) return;
        var inp = document.getElementById('input');
        if (inp) inp.value = data.ip;
        var form = document.getElementById('analyze-form');
        if (form) form.dispatchEvent(new Event('submit', { cancelable: true, bubbles: true }));
      });
      var cp = document.getElementById('fp-copy');
      if (cp) cp.addEventListener('click', function () {
        if (!data) return;
        navigator.clipboard.writeText(JSON.stringify(data, null, 2)).then(function () {
          cp.textContent = 'Copied';
          setTimeout(function () { cp.textContent = 'Copy as JSON'; }, 1400);
        });
      });
    })();
  </script>

  <section id="status" class="hidden"></section>
  <section id="report" class="hidden"></section>

  <script type="module" is:inline>
    // Typed prompt intro. Respects prefers-reduced-motion and skips animation
    // entirely when an ?input= deep-link is present (we want to show results fast).
    (function () {
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const deepLink = new URLSearchParams(location.search).has('input');
      const target = document.getElementById('typed-cmd');
      const cursor = document.getElementById('cursor');
      const headline = document.getElementById('headline');
      const taglines = document.querySelectorAll('.taglines .tagline');
      const pills = document.querySelectorAll('.module-pills .pill');
      const cmd = 'netrecon analyze --input ';

      if (!target) return;

      if (reduce || deepLink) {
        target.textContent = cmd;
        headline?.classList.add('shown');
        taglines.forEach((el) => el.classList.add('shown'));
        pills.forEach((el) => el.classList.add('shown'));
        return;
      }

      headline?.classList.remove('shown');
      let i = 0;
      function step() {
        if (i <= cmd.length) {
          target.textContent = cmd.slice(0, i);
          i++;
          setTimeout(step, 40 + Math.random() * 40);
        } else {
          cursor?.classList.add('blink');
          headline?.classList.add('shown');
          taglines.forEach((el, idx) => setTimeout(() => el.classList.add('shown'), 120 + idx * 180));
          pills.forEach((el, idx) => setTimeout(() => el.classList.add('shown'), 300 + idx * 70));
        }
      }
      setTimeout(step, 200);
    })();
  </script>

  <script type="module" is:inline>
    const form = document.getElementById('analyze-form');
    const input = document.getElementById('input');
    const go = document.getElementById('go');
    const statusEl = document.getElementById('status');
    const reportEl = document.getElementById('report');

    document.querySelectorAll('[data-ex]').forEach((b) =>
      b.addEventListener('click', () => {
        input.value = b.dataset.ex;
        form.dispatchEvent(new Event('submit', { cancelable: true }));
      })
    );

    // Allow sharing / deep links: ?input=...
    const params = new URLSearchParams(location.search);
    if (params.get('input')) {
      input.value = params.get('input');
      setTimeout(() => form.dispatchEvent(new Event('submit', { cancelable: true })), 50);
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const value = input.value.trim();
      if (!value) return;

      const newUrl = new URL(location.href);
      newUrl.searchParams.set('input', value);
      history.replaceState(null, '', newUrl.toString());

      go.disabled = true;
      statusEl.classList.remove('hidden');
      statusEl.innerHTML = '';
      reportEl.classList.add('hidden');
      reportEl.innerHTML = '';

      const progress = renderProgress(statusEl, value);

      try {
        const liveFullEl = document.getElementById('live-full');
        const liveMode = liveFullEl && liveFullEl.checked ? '&live=full' : '';
        const res = await fetch(`/api/analyze?input=${encodeURIComponent(value)}${liveMode}`, { headers: { accept: 'application/json' } });
        const body = await res.json();
        if (!res.ok) throw new Error(body.error || `HTTP ${res.status}`);
        await progress.finish();
        renderReport(body);
      } catch (err) {
        progress.abort();
        statusEl.innerHTML = `<div class="error">${(err && err.message) || err}</div>`;
      } finally {
        go.disabled = false;
      }
    });

    // Staged progress panel. Since the backend runs all modules in parallel and
    // returns a single response, we can't report true per-module progress. Instead
    // we advance stages on a plausible schedule that visually matches what the
    // pipeline is doing, and snap everything to 'done' when the response lands.
    function renderProgress(mount, target) {
      const stages = [
        { id: 'detect',    label: 'detect input',        at: 80 },
        { id: 'dns',       label: 'DNS records',         at: 250 },
        { id: 'ip',        label: 'IP intel + geo/ASN',  at: 400 },
        { id: 'http',      label: 'HTTP probe + headers', at: 600 },
        { id: 'email',     label: 'email posture',       at: 900 },
        { id: 'tls',       label: 'TLS / CT logs',       at: 1200 },
        { id: 'inference', label: 'CDN / ASN inference', at: 1600 },
        { id: 'exposure', label: 'public-internet exposure', at: 1800 },
        { id: 'findings',  label: 'correlate findings',  at: 2100 },
      ];
      const panel = document.createElement('div');
      panel.className = 'progress-panel';
      panel.innerHTML = `
        <div class="progress-head">
          <span class="progress-prompt">$ netrecon analyze <span class="progress-target">${escapeHtml(target)}</span></span>
          <span class="progress-pct" id="progress-pct">0%</span>
        </div>
        <div class="progress-bar"><div class="progress-bar-fill" id="progress-fill"></div></div>
        <ul class="progress-steps">
          ${stages.map(s => `<li id="step-${s.id}" class="pending"><span class="step-icon">○</span><span class="step-label">${s.label}</span><span class="step-detail"></span></li>`).join('')}
        </ul>
      `;
      mount.appendChild(panel);

      const fill = panel.querySelector('#progress-fill');
      const pct = panel.querySelector('#progress-pct');
      const total = stages[stages.length - 1].at + 400;
      const startedAt = performance.now();
      let aborted = false;
      let finishing = false;

      function setStep(id, state, detail) {
        const el = panel.querySelector('#step-' + id);
        if (!el) return;
        el.classList.remove('pending','active','done','error');
        el.classList.add(state);
        const icon = el.querySelector('.step-icon');
        icon.textContent = state === 'done' ? '✓' : state === 'error' ? '✗' : state === 'active' ? '◉' : '○';
        if (detail) el.querySelector('.step-detail').textContent = detail;
      }

      // tick each stage active -> done on its scheduled offset
      const timers = [];
      let activeIdx = 0;
      setStep(stages[0].id, 'active');
      stages.forEach((s, i) => {
        timers.push(setTimeout(() => {
          if (aborted || finishing) return;
          setStep(s.id, 'done');
          if (i + 1 < stages.length) {
            activeIdx = i + 1;
            setStep(stages[i + 1].id, 'active');
          }
        }, s.at));
      });

      // Smooth bar animation driven by elapsed/total, capped at 92% until response lands.
      const raf = { id: 0 };
      function tick() {
        if (aborted || finishing) return;
        const elapsed = performance.now() - startedAt;
        const frac = Math.min(0.92, elapsed / total);
        fill.style.width = (frac * 100).toFixed(1) + '%';
        pct.textContent = Math.round(frac * 100) + '%';
        raf.id = requestAnimationFrame(tick);
      }
      raf.id = requestAnimationFrame(tick);

      return {
        async finish() {
          finishing = true;
          cancelAnimationFrame(raf.id);
          timers.forEach(clearTimeout);
          for (const s of stages) setStep(s.id, 'done');
          fill.style.width = '100%';
          pct.textContent = '100%';
          // short beat so the user sees 100% before the report replaces it
          await new Promise(r => setTimeout(r, 180));
        },
        abort() {
          aborted = true;
          cancelAnimationFrame(raf.id);
          timers.forEach(clearTimeout);
          const active = panel.querySelector('li.active');
          if (active) {
            active.classList.remove('active');
            active.classList.add('error');
            active.querySelector('.step-icon').textContent = '✗';
          }
        },
      };
    }

    function escapeHtml(s) {
      return String(s).replace(/[&<>"']/g, c => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
    }

    function h(tag, attrs = {}, ...children) {
      const el = document.createElement(tag);
      for (const [k, v] of Object.entries(attrs)) {
        if (k === 'class') el.className = v;
        else if (k === 'html') el.innerHTML = v;
        else el.setAttribute(k, v);
      }
      for (const c of children.flat()) {
        if (c == null) continue;
        el.appendChild(typeof c === 'string' ? document.createTextNode(c) : c);
      }
      return el;
    }

    function kv(rows) {
      const tbl = h('table', { class: 'kv' });
      for (const [k, v] of rows) {
        tbl.appendChild(h('tr', {}, h('td', {}, k), h('td', {}, typeof v === 'string' ? v : JSON.stringify(v))));
      }
      return tbl;
    }

    // Lightweight detection for inline decode affordance. Matches decoders.ts heuristics.
    function looksDecodable(value) {
      if (!value || typeof value !== 'string') return null;
      const v = value.trim();
      if (v.length < 12) return null;
      if (/^[A-Za-z0-9_-]+\.[A-Za-z0-9_-]+\.[A-Za-z0-9_-]*$/.test(v)) return 'JWT';
      if (/%[0-9a-fA-F]{2}/.test(v)) return 'URL-encoded';
      const cleaned = v.replace(/\s+/g, '');
      if (/^[A-Za-z0-9+/=]+$/.test(cleaned) && cleaned.length % 4 === 0 && cleaned.length >= 16) return 'base64';
      if (/^[A-Za-z0-9_-]+={0,2}$/.test(cleaned) && cleaned.length >= 16) return 'base64url';
      return null;
    }

    function renderHeadersWithDecode(headers) {
      const tbl = h('table', { class: 'kv' });
      const entries = Object.entries(headers);
      for (const [k, v] of entries) {
        const valStr = typeof v === 'string' ? v : JSON.stringify(v);
        const kind = looksDecodable(valStr);
        const valCell = h('td', {});
        valCell.appendChild(document.createTextNode(valStr));
        if (kind) {
          const link = h('a', {
            class: 'inline-decode',
            href: '/decode#q=' + encodeURIComponent(valStr),
            target: '_blank',
            rel: 'noopener',
            title: 'Open in decoder (stays in your browser)',
          }, 'decode ' + kind);
          valCell.appendChild(link);
        }
        tbl.appendChild(h('tr', {}, h('td', {}, k), valCell));
      }
      return tbl;
    }

    function badge(sev) {
      return h('span', { class: `badge ${sev}` }, sev);
    }

    function renderReport(report) {
      statusEl.classList.add('hidden');
      reportEl.classList.remove('hidden');
      reportEl.innerHTML = '';

      // Summary
      const summary = h('div', { class: 'panel' },
        h('h2', {}, report.summary.title),
        h('div', {}, badge(report.summary.riskLevel), ` risk · ${report.findings.length} findings · ${report.meta.durationMs}ms`),
        h('ul', { class: 'mono' }, ...report.summary.highlights.map((hl) => h('li', {}, hl)))
      );
      reportEl.appendChild(summary);

      // Tabs (IP/Exposure tabs only when data present)
      const hasIp = !!report.modules.ip;
      const hasExposure = !!report.modules.exposure;
      const hasWhois = !!(report.modules.rdap && !report.modules.rdap.skipped);
      const hasAxfr = !!(report.modules.axfr && !report.modules.axfr.skipped && (report.modules.axfr.attempts || []).length > 0);
      const tabs = ['Findings', ...(hasIp ? ['IP'] : []), ...(hasExposure ? ['Exposure'] : []), 'DNS', 'HTTP', 'Email', 'TLS', ...(hasWhois ? ['Whois'] : []), ...(hasAxfr ? ['AXFR'] : []), 'Inference', 'Commands', 'Raw JSON'];
      const tabBar = h('div', { class: 'tabs' });
      const panels = {};
      tabs.forEach((t, i) => {
        const btn = h('button', { class: i === 0 ? 'active' : '' }, t);
        btn.addEventListener('click', () => {
          tabBar.querySelectorAll('button').forEach((b) => b.classList.remove('active'));
          btn.classList.add('active');
          Object.values(panels).forEach((p) => p.classList.add('hidden'));
          panels[t].classList.remove('hidden');
        });
        tabBar.appendChild(btn);
      });
      reportEl.appendChild(tabBar);

      // Findings panel
      const findingsPanel = h('div', { class: 'panel' });
      if (!report.findings.length) {
        findingsPanel.appendChild(h('div', { class: 'loading' }, 'No findings emitted. Everything the engine knows how to check looks normal.'));
      }
      for (const f of report.findings) {
        const item = h('div', { class: 'finding' },
          h('div', { class: 'title' }, badge(f.severity), f.title),
          h('div', { class: 'explanation' }, f.explanation),
          f.evidence.length ? h('div', {}, h('strong', {}, 'Evidence'), h('ul', {}, ...f.evidence.map((x) => h('li', {}, h('code', {}, x))))) : null,
          f.nextSteps.length ? h('div', {}, h('strong', {}, 'Next steps'), h('ul', {}, ...f.nextSteps.map((x) => h('li', {}, x)))) : null,
          f.suggestedCommands.length ? h('div', {}, h('strong', {}, 'Commands'), ...f.suggestedCommands.map((c) => h('pre', { class: 'cmd' }, c))) : null,
        );
        findingsPanel.appendChild(item);
      }
      panels['Findings'] = findingsPanel;
      reportEl.appendChild(findingsPanel);

      // IP (only when present)
      if (hasIp) {
        const ip = report.modules.ip;
        const ipPanel = h('div', { class: 'panel hidden' });
        const geo = ip.geo || {};
        ipPanel.appendChild(kv([
          ['IP', ip.ip],
          ['Version', ip.version.toUpperCase()],
          ['Scope', ip.scope + (ip.anycast?.likely ? ' · anycast' : '')],
          ['Country', [geo.city, geo.region, geo.country ? `${geo.country} (${geo.countryCode || ''})` : ''].filter(Boolean).join(', ') || '-'],
          ['Coordinates', (geo.latitude != null && geo.longitude != null) ? `${geo.latitude}, ${geo.longitude}` : '-'],
          ['Timezone', geo.timezone || '-'],
          ['Organization', geo.org || geo.isp || '-'],
          ['ASN', ip.asn ? `AS${ip.asn.asn}${ip.asn.owner ? ' ' + ip.asn.owner : ''}` : '-'],
          ['Registry', ip.asn?.registry || '-'],
          ['PTR', ip.ptr.length ? ip.ptr.join(', ') : '-'],
          ['Notes', ip.notes.join('; ') || '-'],
          ['Anycast hint', ip.anycast?.reason || '-'],
        ]));
        panels['IP'] = ipPanel;
        reportEl.appendChild(ipPanel);
      }

      // Exposure (third-party observed internet posture)
      if (hasExposure) {
        const s = report.modules.exposure;
        const shPanel = h('div', { class: 'panel hidden' });
        if (s.skipped) {
          shPanel.appendChild(h('div', { class: 'loading' }, s.skipReason || 'Exposure data unavailable.'));
        } else if (s.kind === 'host') {
          shPanel.appendChild(h('div', { class: 'loading' }, `Public-internet posture for ${s.ip} · last observed ${s.lastUpdate || '-'}`));
          shPanel.appendChild(kv([
            ['Open ports', (s.ports || []).join(', ') || '-'],
            ['Organization', s.org || '-'],
            ['ISP', s.isp || '-'],
            ['ASN', s.asn || '-'],
            ['OS', s.os || '-'],
            ['Tags', (s.tags || []).join(', ') || '-'],
            ['Hostnames', (s.hostnames || []).join(', ') || '-'],
            ['Known CVEs', (s.vulns || []).join(', ') || '-'],
          ]));
          if (s.services && s.services.length) {
            shPanel.appendChild(h('h3', {}, 'Services observed'));
            for (const svc of s.services) {
              const header = `${svc.port}/${svc.transport || 'tcp'} · ${svc.product || 'unknown'}${svc.version ? ' ' + svc.version : ''}`;
              shPanel.appendChild(h('div', { class: 'finding' },
                h('div', { class: 'title' }, header),
                svc.cpe.length ? h('div', {}, h('strong', {}, 'CPE'), h('pre', { class: 'cmd' }, svc.cpe.join('\n'))) : null,
                svc.ssl ? h('div', {}, h('strong', {}, 'Observed cert'), h('pre', { class: 'cmd' }, `subject: ${svc.ssl.subjectCn || '-'}\nissuer: ${svc.ssl.issuerCn || '-'}\nnotBefore: ${svc.ssl.notBefore || '-'}\nnotAfter: ${svc.ssl.notAfter || '-'}\nversions: ${(svc.ssl.versions || []).join(', ') || '-'}`)) : null,
              ));
            }
          }
        } else {
          // Domain
          shPanel.appendChild(h('div', { class: 'loading' }, `Internet-wide posture for ${s.domain}`));
          const expo = s.exposure;
          shPanel.appendChild(kv([
            ['Subdomains (passive)', String((s.subdomains || []).length)],
            ['Hosts mentioning hostname', expo?.hostnameMatches != null ? String(expo.hostnameMatches) : '-'],
            ['Hosts serving cert for name', expo?.certMatches != null ? String(expo.certMatches) : '-'],
            ['Tags', (s.tags || []).join(', ') || '-'],
          ]));

          const renderFacet = (title, rows) => {
            if (!rows || !rows.length) return;
            shPanel.appendChild(h('h3', {}, title));
            shPanel.appendChild(kv(rows.slice(0, 10).map((r) => [String(r.value), String(r.count)])));
          };
          if (expo?.facets) {
            renderFacet('Top ports (across matching hosts)', expo.facets.port);
            renderFacet('Top organizations', expo.facets.org);
            renderFacet('Top products detected', expo.facets.product);
            renderFacet('Top countries', expo.facets.country);
            renderFacet('Top CVEs seen on matching hosts', expo.facets.vuln);
            renderFacet('TLS versions observed', expo.facets.sslVersion);
          }

          if (s.subdomains && s.subdomains.length) {
            shPanel.appendChild(h('h3', {}, 'Subdomains observed'));
            shPanel.appendChild(h('pre', { class: 'cmd' }, s.subdomains.slice(0, 100).join('\n') + (s.subdomains.length > 100 ? `\n... +${s.subdomains.length - 100} more` : '')));
          }
        }
        panels['Exposure'] = shPanel;
        reportEl.appendChild(shPanel);
      }

      // DNS
      const dns = report.modules.dns;
      const dnsPanel = h('div', { class: 'panel hidden' });
      if (!dns || !dns.ok) {
        dnsPanel.appendChild(h('div', { class: 'loading' }, dns?.skipReason || dns?.error || 'No DNS data.'));
      } else {
        for (const [type, recs] of Object.entries(dns.records)) {
          if (!recs.length) continue;
          dnsPanel.appendChild(h('h3', {}, type));
          dnsPanel.appendChild(h('pre', { class: 'cmd' }, recs.map((r) => `${r.name}\t${r.ttl ?? ''}\t${r.data}`).join('\n')));
        }
        dnsPanel.appendChild(h('h3', {}, 'Meta'));
        dnsPanel.appendChild(kv([['IPv6', String(dns.hasIPv6)], ['CAA', String(dns.hasCAA)], ['DNSSEC (AD)', String(dns.dnssec ?? 'unknown')]]));
      }
      panels['DNS'] = dnsPanel;
      reportEl.appendChild(dnsPanel);

      // HTTP
      const http = report.modules.http;
      const httpPanel = h('div', { class: 'panel hidden' });
      if (!http || !http.ok) {
        httpPanel.appendChild(h('div', { class: 'loading' }, http?.skipReason || http?.error || 'No HTTP data.'));
      } else {
        httpPanel.appendChild(kv([
          ['Final URL', http.finalUrl],
          ['Status', http.status],
          ['Server', http.server || '-'],
          ['Timing (ms)', http.timingMs],
        ]));
        if (http.redirects.length) {
          httpPanel.appendChild(h('h3', {}, 'Redirect chain'));
          httpPanel.appendChild(h('pre', { class: 'cmd' }, http.redirects.map((r) => `${r.status}  ${r.from}\n  -> ${r.to}`).join('\n')));
        }
        httpPanel.appendChild(h('h3', {}, 'Security headers'));
        httpPanel.appendChild(kv(Object.entries(http.securityHeaders).map(([k, v]) => [k, v || '(missing)'])));
        httpPanel.appendChild(h('h3', {}, 'Cache headers'));
        httpPanel.appendChild(kv(Object.entries(http.cacheHeaders).map(([k, v]) => [k, v || '(missing)'])));
        httpPanel.appendChild(h('h3', {}, 'All response headers'));
        httpPanel.appendChild(renderHeadersWithDecode(http.headers));
      }
      panels['HTTP'] = httpPanel;
      reportEl.appendChild(httpPanel);

      // Email
      const em = report.modules.email;
      const emPanel = h('div', { class: 'panel hidden' });
      if (!em || em.skipped) {
        emPanel.appendChild(h('div', { class: 'loading' }, em?.skipReason || 'Email posture requires a domain.'));
      } else {
        emPanel.appendChild(kv([
          ['MX present', String(em.mxPresent)],
          ['SPF', em.spf?.present ? (em.spf.raw || 'yes') : 'missing'],
          ['SPF qualifier', em.spf?.qualifier || '-'],
          ['DMARC', em.dmarc?.present ? (em.dmarc.raw || 'yes') : 'missing'],
          ['DMARC policy', em.dmarc?.policy || '-'],
          ['MTA-STS TXT', em.mtaSts?.present ? (em.mtaSts.raw || 'yes') : 'missing'],
          ['BIMI', em.bimi?.present ? (em.bimi.raw || 'yes') : 'missing'],
        ]));
        if (em.dkimSelectorProbe?.length) {
          emPanel.appendChild(h('h3', {}, 'DKIM selector probe'));
          emPanel.appendChild(kv(em.dkimSelectorProbe.map((p) => [p.selector, p.present ? '✓ ' + (p.raw?.slice(0, 80) || '') : '✗'])));
        }
      }
      panels['Email'] = emPanel;
      reportEl.appendChild(emPanel);

      // Whois (RDAP)
      if (hasWhois) {
        const rdap = report.modules.rdap;
        const whoisPanel = h('div', { class: 'panel hidden' });
        if (!rdap.ok) {
          whoisPanel.appendChild(h('div', { class: 'loading' }, rdap.error || 'RDAP lookup failed.'));
        } else {
          const d = rdap.daysUntilExpiry;
          let expiryLabel = '-';
          if (rdap.expiresAt) {
            const tag = d == null ? '' : d < 0 ? ' · EXPIRED' : d < 14 ? ` · ${d}d left` : d < 60 ? ` · ${d}d left` : ` · ${d}d left`;
            expiryLabel = rdap.expiresAt + tag;
          }
          whoisPanel.appendChild(kv([
            ['Registrar', rdap.registrar || '-'],
            ['Registered', rdap.registeredAt || '-'],
            ['Expires', expiryLabel],
            ['Last changed', rdap.lastChangedAt || '-'],
            ['Abuse contact', rdap.abuseEmail || '-'],
            ['DNSSEC signed', rdap.dnssecSigned == null ? '-' : String(rdap.dnssecSigned)],
            ['Status flags', (rdap.status || []).join(', ') || '-'],
            ['Nameservers', (rdap.nameservers || []).join(', ') || '-'],
          ]));
          whoisPanel.appendChild(h('p', { class: 'mono', style: 'opacity:.6;font-size:.85em;margin-top:12px' },
            'Source: rdap.org → authoritative registry RDAP. Some ccTLDs (e.g., .il) have no RDAP server and are reported as "skipped" on the Raw JSON tab.'));
        }
        panels['Whois'] = whoisPanel;
        reportEl.appendChild(whoisPanel);
      }

      // AXFR
      if (hasAxfr) {
        const axfr = report.modules.axfr;
        const axfrPanel = h('div', { class: 'panel hidden' });
        const openCount = (axfr.attempts || []).filter((a) => a.status === 'open').length;
        if (openCount > 0) {
          axfrPanel.appendChild(h('div', { class: 'finding severity-high' },
            h('strong', {}, `⚠ ${openCount} nameserver(s) accepted AXFR`),
            h('div', {}, 'This leaks your full zone. See Findings tab for remediation.')));
        } else {
          axfrPanel.appendChild(h('div', { class: 'loading' }, 'No nameserver allowed zone transfer (correct behavior).'));
        }
        axfrPanel.appendChild(kv((axfr.attempts || []).map((a) => [
          a.ns,
          `${a.status}${a.rcodeName ? ' · ' + a.rcodeName : ''}${a.ancount != null ? ' · ancount=' + a.ancount : ''}${a.elapsedMs != null ? ' · ' + a.elapsedMs + 'ms' : ''}${a.error ? ' · ' + a.error : ''}`,
        ])));
        axfrPanel.appendChild(h('p', { class: 'mono', style: 'opacity:.6;font-size:.85em;margin-top:12px' },
          'Probes up to 2 of the zone\'s NS records on TCP/53. "refused" / "timeout" are the expected, correct outcomes.'));
        panels['AXFR'] = axfrPanel;
        reportEl.appendChild(axfrPanel);
      }

      // TLS
      const tls = report.modules.tls;
      const tlsPanel = h('div', { class: 'panel hidden' });
      const renderLiveTls = () => {
        if (!tls?.liveTls || (!tls.liveTls.version && !tls.liveTls.cipher)) return;
        tlsPanel.appendChild(h('h3', {}, 'Live session (probe)'));
        tlsPanel.appendChild(kv([
          ['Version', tls.liveTls.version || '-'],
          ['Cipher', tls.liveTls.cipher || '-'],
        ]));
      };
      if (!tls || tls.skipped || tls.source === 'unavailable') {
        tlsPanel.appendChild(h('div', { class: 'loading' }, tls?.skipReason || 'TLS inspection unavailable.'));
        renderLiveTls();
      } else if (tls.latestCertificate) {
        const note = tls.hostSearched && report.input.type === 'ip'
          ? `Source: Certificate Transparency logs. Searched by PTR hostname "${tls.hostSearched}" since CT indexes by name, not IP.`
          : 'Most recent certificate issuance found in Certificate Transparency logs across this domain and its subdomains. This is not necessarily the certificate being served — see "Live peer certificate" below for the cert actually returned by the origin.';
        tlsPanel.appendChild(h('div', { class: 'loading' }, note));
        tlsPanel.appendChild(kv([
          ['Issuer', tls.latestCertificate.issuer],
          ['Common Name', tls.latestCertificate.commonName || '-'],
          ['Not Before', tls.latestCertificate.notBefore],
          ['Not After', tls.latestCertificate.notAfter],
          ['Days until expiry', tls.latestCertificate.daysUntilExpiry],
          ['Recent CT entries', tls.recentCount],
        ]));
        tlsPanel.appendChild(h('h3', {}, 'SANs'));
        tlsPanel.appendChild(h('pre', { class: 'cmd' }, tls.latestCertificate.sans.join('\n')));
        renderLiveTls();
      } else {
        tlsPanel.appendChild(h('div', { class: 'loading' }, `No certificates found in CT logs for ${tls.hostSearched || 'this host'}.`));
        renderLiveTls();
      }

      // Live peer TLS section (new) — the actual cert being served right now,
      // via raw-TCP fast path or Browser Rendering fallback.
      const lt = report.modules.livetls;
      if (lt) {
        tlsPanel.appendChild(h('hr', { class: 'sep' }));
        tlsPanel.appendChild(h('h3', {}, 'Live peer certificate'));
        if (lt.skipped) {
          tlsPanel.appendChild(h('div', { class: 'loading' }, lt.skipReason || 'Live peer TLS skipped.'));
        } else if (!lt.ok) {
          const reason = lt.error || 'Live peer TLS probe failed.';
          tlsPanel.appendChild(h('div', { class: 'loading' }, reason));
          if (lt.alert && lt.alert.description) {
            tlsPanel.appendChild(h('div', { class: 'loading mono' }, 'TLS alert: ' + lt.alert.description));
          }
          if (!report.modules.livetls.source || report.modules.livetls.source === 'raw-tcp') {
            tlsPanel.appendChild(h('div', { class: 'loading' }, 'Tip: tick "live TLS: full" above to enable Browser Rendering fallback for CF-fronted and TLS 1.3-only targets.'));
          }
        } else if (lt.certs && lt.certs.length) {
          const c = lt.certs[0];
          const sourceLabel = lt.source === 'browser-rendering'
            ? `Browser Rendering (fallback${lt.fastPathError ? ': raw TCP failed — ' + lt.fastPathError : ''})`
            : 'Raw TCP fast path';
          const note = lt.source === 'browser-rendering'
            ? 'Source: live handshake via headless Chromium (Cloudflare Browser Rendering). This is what a real browser sees.'
            : 'Source: live TLS 1.2 handshake over raw TCP. Certificate actually being served right now.';
          tlsPanel.appendChild(h('div', { class: 'loading' }, note));
          tlsPanel.appendChild(kv([
            ['Source', sourceLabel + (lt.durationMs != null ? ` · ${lt.durationMs}ms` : '')],
            ['Negotiated version', lt.negotiatedVersion || '-'],
            ['Cipher', lt.cipherSuite || '-'],
            ['Subject', c.subject || '-'],
            ['Issuer', c.issuer || '(empty in CDP response — Browser Rendering does not always expose issuer for CF-fronted targets)'],
            ['Hostname match', lt.hostnameMatch === true ? '✓' : lt.hostnameMatch === false ? '✗' : '-'],
            ['Not Before', c.notBefore || '-'],
            ['Not After', c.notAfter || '-'],
            ['Days until expiry', c.daysUntilExpiry],
            ['Expired', c.expired ? 'yes' : 'no'],
            ['Self-signed', c.selfSigned ? 'yes' : 'no'],
            ['Signature alg', c.signatureAlgorithm || '-'],
            ['Public key alg', c.publicKeyAlgorithm || '-'],
            ['Serial', c.serialNumber || '-'],
            ['SHA-256 fingerprint', c.fingerprintSha256 || '-'],
          ]));
          if (c.sans && c.sans.length) {
            tlsPanel.appendChild(h('h4', {}, 'SANs (peer)'));
            tlsPanel.appendChild(h('pre', { class: 'cmd' }, c.sans.join('\n')));
          }
          if (lt.notes && lt.notes.length) {
            tlsPanel.appendChild(h('h4', {}, 'Notes'));
            const ul = h('ul', { class: 'note-list' });
            lt.notes.forEach(function (n) { ul.appendChild(h('li', {}, n)); });
            tlsPanel.appendChild(ul);
          }
        }
      }
      panels['TLS'] = tlsPanel;
      reportEl.appendChild(tlsPanel);

      // Inference
      const inf = report.modules.inference;
      const infPanel = h('div', { class: 'panel hidden' });
      if (!inf) {
        infPanel.appendChild(h('div', { class: 'loading' }, 'No inference data.'));
      } else {
        infPanel.appendChild(kv([
          ['CDN detected', inf.cdn?.detected ? inf.cdn.name || 'yes' : 'no'],
          ['ASN', inf.asn?.asn ? `AS${inf.asn.asn} ${inf.asn.owner || ''}`.trim() : '-'],
          ['ASN country', inf.asn?.cc || '-'],
          ['Proxy hints', inf.proxyHints.join(', ') || '-'],
          ['Origin exposure risk', inf.originExposureRisk ? `${inf.originExposureRisk.risk}: ${inf.originExposureRisk.reason}` : '-'],
        ]));
        if (inf.cdn?.evidence?.length) {
          infPanel.appendChild(h('h3', {}, 'Evidence'));
          infPanel.appendChild(h('pre', { class: 'cmd' }, inf.cdn.evidence.join('\n')));
        }
      }
      panels['Inference'] = infPanel;
      reportEl.appendChild(infPanel);

      // Commands
      const cmdPanel = h('div', { class: 'panel hidden' });
      cmdPanel.appendChild(h('div', { class: 'loading' }, 'Reproducible commands - copy into your terminal to verify each check.'));
      for (const c of report.generatedCommands) {
        cmdPanel.appendChild(h('pre', { class: 'cmd' }, c));
      }
      panels['Commands'] = cmdPanel;
      reportEl.appendChild(cmdPanel);

      // Raw
      const rawPanel = h('div', { class: 'panel hidden' });
      rawPanel.appendChild(h('div', { class: 'loading' }, 'Full machine-readable report - identical to what POST /api/analyze returns.'));
      rawPanel.appendChild(h('pre', { class: 'json' }, JSON.stringify(report, null, 2)));
      panels['Raw JSON'] = rawPanel;
      reportEl.appendChild(rawPanel);
    }
  </script>
</Layout>
